{
  "name": "api",
  "version": "1.0.0",
  "description": "",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "db:up": "cd ../.. && docker compose up -d",
    "db:down": "cd ../.. && docker compose down",
    "db:migrate": "knex migrate:latest --knexfile knexfile.js",
    "db:rollback": "knex migrate:rollback --knexfile knexfile.js",
    "db:status": "knex migrate:status --knexfile knexfile.js",
    "test:db": "cross-env NODE_ENV=test vitest run -c vitest.int.config.js",
    "test:db:watch": "cross-env NODE_ENV=test vitest -c vitest.int.config.js --watch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "knex": "^3.1.0",
    "mysql2": "^3.16.0"
  },
  "devDependencies": {
    "dotenv": "^17.2.3",
    "nodemon": "^3.1.11",
    "supertest": "^7.1.4",
    "vitest": "^4.0.16"
  }
}
