############################
# Application Environment
############################

# development | test | production
NODE_ENV=

# Server port
PORT=


############################
# Frontend / CORS
############################

# Required in production
# Example: https://example.com
FRONTEND_ORIGIN=


############################
# Database Provider
############################

# mysql | memory
DB_PROVIDER=

# Force MySQL usage (optional)
# DB_USE_MYSQL=1


############################
# Database Connection
############################

DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=


############################
# Test Database
############################

# Used when NODE_ENV=test
DB_NAME_TEST=

# Enable MySQL for integration tests only
# DB_INTEGRATION=1


############################
# Database SSL (Production)
############################

# Enable SSL for MySQL connections
# DB_SSL=1

# Disable certificate validation (only if provider requires it)
# DB_SSL_REJECT_UNAUTHORIZED=0

############################
# JWT & Authentication
############################

JWT_SECRET=
JWT_EXPIRES_IN= 

# Refresh token expiration in days 
REFRESH_TOKEN_EXPIRES_IN_DAYS= 

# Refresh token pepper for hashing security
# REQUIRED in production - use a long random secret
# Example: openssl rand -hex 32
REFRESH_TOKEN_PEPPER=

############################
# Password Reset
############################

RESET_CODE_PEPPER=9b2af6de8f7c0a2c17456d953ba4ea7f4f17b7f6d6d2a8cc2a2b170eb819f6d1
RESET_CODE_EXPIRES_MINUTES=15

############################
# Resend
############################

RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev

############################
# App / URLs
############################

APP_PUBLIC_URL=http://localhost:5173

############################
# Google OAuth
############################

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/oauth/google/callback


CLOUDINARY_CLOUD_NAME=xxxxx
CLOUDINARY_API_KEY=xxxxx
CLOUDINARY_API_SECRET=xxxxx