############################
# Application Environment
############################

# development | test | production
NODE_ENV=

# Server port
PORT=


############################
# Frontend / CORS
############################

# Required in production
# Example: https://example.com
FRONTEND_ORIGIN=


############################
# Database Provider
############################

# mysql | memory
DB_PROVIDER=

# Force MySQL usage (optional)
# DB_USE_MYSQL=1


############################
# Database Connection
############################

DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=


############################
# Test Database
############################

# Used when NODE_ENV=test
DB_NAME_TEST=

# Enable MySQL for integration tests only
# DB_INTEGRATION=1


############################
# Database SSL (Production)
############################

# Enable SSL for MySQL connections
# DB_SSL=1

# Disable certificate validation (only if provider requires it)
# DB_SSL_REJECT_UNAUTHORIZED=0

############################
# JWT & Authentication
############################

JWT_SECRET=
JWT_EXPIRES_IN= 

# Refresh token expiration in days 
REFRESH_TOKEN_EXPIRES_IN_DAYS= 

# Refresh token pepper for hashing security
# REQUIRED in production - use a long random secret
# Example: openssl rand -hex 32
REFRESH_TOKEN_PEPPER=

############################
# Password Reset
############################

RESET_CODE_PEPPER=
RESET_CODE_EXPIRES_MINUTES=

############################
# Resend
############################

RESEND_API_KEY=
RESEND_FROM=

############################
# Admin Notifications
############################

# Email address to receive admin notifications (payment submissions, etc.)
ADMIN_NOTIFICATION_EMAIL=

############################
# Voiceflow Integration
############################

# API key for Voiceflow chatbot integration
# REQUIRED in production
VOICEFLOW_API_KEY=

############################
# App / URLs
############################

APP_PUBLIC_URL=

############################
# Google OAuth
############################

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=


CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=