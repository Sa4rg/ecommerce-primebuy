############################
# Application Environment
############################

# development | test | production
NODE_ENV=development

# Server port
PORT=3000


############################
# Frontend / CORS
############################

# Required in production
# Example: https://example.com
FRONTEND_ORIGIN=http://localhost:5173


############################
# Database Provider
############################

# mysql | memory
DB_PROVIDER=mysql

# Force MySQL usage (optional)
# DB_USE_MYSQL=1


############################
# Database Connection
############################

DB_HOST=localhost
DB_PORT=3307
DB_USER=ecommerce
DB_PASSWORD=ecommerce
DB_NAME=ecommerce_dev


############################
# Test Database
############################

# Used when NODE_ENV=test
DB_NAME_TEST=ecommerce_test

# Enable MySQL for integration tests only
# DB_INTEGRATION=1


############################
# Database SSL (Production)
############################

# Enable SSL for MySQL connections
# DB_SSL=1

# Disable certificate validation (only if provider requires it)
# DB_SSL_REJECT_UNAUTHORIZED=0

############################
# JWT & Authentication
############################

JWT_SECRET=super-secret-test-key
JWT_EXPIRES_IN=1h

# Refresh token expiration in days (default: 7)
REFRESH_TOKEN_EXPIRES_IN_DAYS=7

# Refresh token pepper for hashing security
# REQUIRED in production - use a long random secret
# Example: openssl rand -hex 32
REFRESH_TOKEN_PEPPER=change-me-in-production
